{
  "name": "rolestab",
  "private": true,
  "version": "0.2.0",
  "description": "A desktop mini-browser for testing multiple isolated user role sessions.",
  "desktopName": "RolesTab",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5174 --strictPort\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://127.0.0.1:5174 dist-electron/main/index.js && powershell -NoProfile -Command \\\"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; electron .\\\"\"",
    "build": "tsc -b && tsc -p tsconfig.electron.json && vite build",
    "electron": "powershell -NoProfile -Command \"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; electron .\"",
    "lint": "eslint .",
    "test": "npm run build && node --test tests/smoke.test.cjs",
    "preview": "vite preview",
    "stats:downloads": "node scripts/github-release-downloads.mjs",
    "dist": "npm run build && electron-builder --publish never",
    "dist:dir": "npm run build && electron-builder --dir --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "author": "RolesTab",
  "license": "UNLICENSED",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "concurrently": "^10.0.3",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.rolestab.app",
    "productName": "RolesTab",
    "artifactName": "RolesTab-${version}-${os}-${arch}.${ext}",
    "copyright": "Copyright © 2026 RolesTab",
    "asar": true,
    "compression": "maximum",
    "icon": "public/favicon",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Usenmfon",
        "repo": "rolestab"
      }
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!**/*.map",
      "!src/**",
      "!tests/**",
      "!docs/**"
    ],
    "extraMetadata": {
      "main": "dist-electron/main/index.js"
    },
    "win": {
      "icon": "public/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RolesTab",
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "Development",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "RolesTab"
    }
  }
}
