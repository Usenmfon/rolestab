{
  "name": "rolestab",
  "private": true,
  "version": "0.1.0",
  "description": "A desktop mini-browser for testing multiple isolated user role sessions.",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:5173 dist-electron/main/index.js && powershell -NoProfile -Command \\\"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; electron .\\\"\"",
    "build": "tsc -b && tsc -p tsconfig.electron.json && vite build",
    "electron": "powershell -NoProfile -Command \"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; electron .\"",
    "lint": "eslint .",
    "test": "node --test tests/smoke.test.cjs",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "author": "RolesTab",
  "license": "UNLICENSED",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.rolestab.app",
    "productName": "RolesTab",
    "artifactName": "RolesTab-${version}-${os}-${arch}.${ext}",
    "icon": "public/favicon.svg",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
